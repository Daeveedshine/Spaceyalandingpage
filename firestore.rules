rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }
    
    // Entity Validators
    function isValidWaitlistEntry(data) {
      return data.fullName is string &&
             data.email is string &&
             data.phoneNumber is string &&
             data.userType is string && 
             data.propertyCount is string;
    }

    // Waitlist collection
    match /waitlist/{waitlistId} {
      // Anyone can create an entry to the waitlist. Reading and modifying are not allowed.
      allow create: if isValidId(waitlistId) && isValidWaitlistEntry(incoming());
      
      // Admin dashboard might need read access later, but for now we block reads to protect PII.
    }
  }
}
